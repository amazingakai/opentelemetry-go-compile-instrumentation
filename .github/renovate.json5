{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    'helpers:pinGitHubActionDigestsToSemver',
  ],
  schedule: [
    'before 8am on the 1st and 15th day of the month',
  ],
  updateNotScheduled: false,
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'WEAVER_IMAGE\\s*\\?=\\s*(?<depName>[^:]+):v(?<currentValue>[^\\s]+)',
      ],
      datasourceTemplate: 'docker',
    },
  ],
  packageRules: [
    {
      matchFileNames: [
        '.github/**',
      ],
      enabled: false,
    },
    {
      groupName: 'all dependencies',
      groupSlug: 'all-deps',
      matchUpdateTypes: [
        'patch',
        'minor',
        'major',
        'digest',
      ],
      matchPackageNames: [
        '*',
      ],
    },
  ],
  labels: [
    'dependencies',
  ],
}
